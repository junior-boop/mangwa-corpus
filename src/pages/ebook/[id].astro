---
import Layout from "../../layouts/Layout.astro";
import Header from "../../Componant/Header";
import Footer from "../../Componant/Footer";
import Container from "../../Componant/Container";
import EbookDetailViewer from "../../Componant/EbookDetailViewer";
import { books } from "../../data/books";

export function getStaticPaths() {
  return books.map((book) => ({
    params: { id: book.id },
    props: { book },
  }));
}

const { book } = Astro.props;
---

<Layout>
  <Header client:load />

  <Container>
    <nav class="flex items-center gap-2 text-[13px] text-gray-400 mt-6 mb-2">
      <a href="/ebook" class="hover:text-gray-700 transition-colors">E-Book</a>
      <span>/</span>
      <span class="text-gray-700 font-medium">{book.titre}</span>
    </nav>

    <EbookDetailViewer client:load id={book.id} />
  </Container>

  <Footer client:load />
</Layout>
