---
import Layout from "../../layouts/Layout.astro";
import Header from "../../Componant/Header";
import Footer from "../../Componant/Footer";
import Container from "../../Componant/Container";
import AudioItemPlayer from "../../Componant/AudioItemPlayer";
import { tracks } from "../../data/tracks";

export function getStaticPaths() {
  return tracks.map((track) => ({
    params: { id: track.id },
    props: { track },
  }));
}

const { track } = Astro.props;
---

<Layout>
  <Header client:load />

  <Container>
    <div class="py-6">
      <nav class="flex items-center gap-2 text-[13px] text-gray-400 mb-6">
        <a href="/audio" class="hover:text-gray-700 transition-colors">Audios</a>
        <span>/</span>
        <span class="text-gray-700 font-medium">{track.titre}</span>
      </nav>

      <AudioItemPlayer client:load id={track.id} />
    </div>
  </Container>

  <Footer client:load />
</Layout>
