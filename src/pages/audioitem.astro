---
import Layout from "../layouts/Layout.astro";
import Header from "../Componant/Header";
import Footer from "../Componant/Footer";
import Container from "../Componant/Container";
import AudioItemPlayer from "../Componant/AudioItemPlayer";
import { lyricsAudioTest } from "../data/lyrics_audio_test";
import audioTest from "../assets/audio_test.mp3";
---

<Layout>
  <Header client:load />

  <Container>
    <div class="py-6">
      <!-- Fil d'ariane -->
      <nav class="flex items-center gap-2 text-[13px] text-gray-400 mb-6">
        <a href="/audio" class="hover:text-gray-700 transition-colors">Audios</a>
        <span>/</span>
        <span class="text-gray-700 font-medium">Titre de la musique</span>
      </nav>

      <AudioItemPlayer
        client:load
        titre="Titre de la musique"
        artiste="Artiste"
        audioUrl={audioTest}
        lyrics={lyricsAudioTest}
      />
    </div>
  </Container>

  <Footer client:load />
</Layout>
