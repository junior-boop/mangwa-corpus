---
import "../styles/global.css";

interface Props {
  title?: string;
  active?: string;
}

const { title = "Administration", active = "" } = Astro.props;

const nav = [
  { href: "/admin", label: "Tableau de bord", key: "dashboard" },
  { href: "/admin/magazines", label: "Magazines", key: "magazines" },
  { href: "/admin/audios", label: "Audios", key: "audios" },
  { href: "/admin/videos", label: "Vidéos", key: "videos" },
  { href: "/admin/hero", label: "Bannières", key: "hero" },
  { href: "/admin/media", label: "Médias", key: "media" },
  { href: "/admin/users", label: "Utilisateurs", key: "users" },
  { href: "/admin/newsletter", label: "Newsletter", key: "newsletter" },
  { href: "/admin/payment-methods", label: "Méthodes de paiement", key: "payment-methods" },
  { href: "/admin/payments", label: "Paiements", key: "payments" },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} — Mangwa Admin</title>
  </head>
  <body class="bg-gray-100 h-screen flex overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-60 bg-gray-900 text-white flex flex-col shrink-0 h-full overflow-y-auto">
      <div class="px-6 py-5 border-b border-gray-700">
        <p class="font-bold text-sm uppercase tracking-widest text-[#00bcd4]">Mangwa Corpus</p>
        <p class="text-xs text-gray-400 mt-0.5">Administration</p>
      </div>
      <nav class="flex flex-col py-4 gap-1 flex-1">
        {nav.map((item) => (
          <a
            href={item.href}
            class={`px-6 py-2.5 text-sm font-medium transition-colors ${
              active === item.key
                ? "bg-[#00bcd4] text-white"
                : "text-gray-300 hover:bg-gray-800 hover:text-white"
            }`}
          >
            {item.label}
          </a>
        ))}
      </nav>
      <div class="px-6 py-4 border-t border-gray-700">
        <a href="/" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">← Retour au site</a>
      </div>
    </aside>

    <!-- Main -->
    <main class="flex-1 p-8 overflow-auto">
      <h1 class="text-2xl font-extrabold text-gray-900 mb-6">{title}</h1>
      <slot />
    </main>

  </body>
</html>
